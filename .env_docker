# PostgreSQL
POSTGRES_HOST=db # bsc docker network
POSTGRES_USER=user_local
POSTGRES_PASSWORD=password
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# MongoDB Configuration
MONGODB_HOST=mongo # bcs docker network
MONGODB_PORT=27017
MONGODB_DB=iot_platform
MONGODB_USER=
MONGODB_PASSWORD=

# MQTT Broker
MQTT_BROKER_HOST=devices
MQTT_BROKER_PORT=1883

# Modbus TCP Configuration
MODBUS_SERVER_HOST=devices
MODBUS_SERVER_PORT=5020             # Non-privileged port (doesn't require root)
MODBUS_SERVER_POLL_INTERVAL=5
MODBUS_CLIENT_POLL_INTERVAL=10